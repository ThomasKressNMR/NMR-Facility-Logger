      "targets": [
        {
          "query": "// Calculate time until minimum helium level for multiple spectrometers\n// Define minimum acceptable helium level\nminLevel = 70.0\n\n// Get latest helium loss rate for each spectrometer (from the last derivative calculation)\nheliumLossRates = from(bucket: \"BSMS\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"bsms\")\n  |> filter(fn: (r) => r[\"_field\"] == \"helium_level\")\n  |> aggregateWindow(every: 1d, fn: mean, createEmpty: false)\n  |> derivative(unit: 1d, nonNegative: false)\n  |> filter(fn: (r) => r._value < 0.0)  // Keep only negative drift rates\n  |> group(columns: [\"spectrometer\"])\n  |> last()  // Get only the last reading for each spectrometer\n  |> keep(columns: [\"_value\", \"spectrometer\"])\n  |> map(fn: (r) => ({ r with _value: r._value * -1.0 }))  // Convert to positive value\n\n// Get current helium levels for each spectrometer\ncurrentLevels = from(bucket: \"BSMS\")\n  |> range(start: -1w)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"bsms\")\n  |> filter(fn: (r) => r[\"_field\"] == \"helium_level\")\n  |> group(columns: [\"spectrometer\"])\n  |> last()  // Get only the last reading for each spectrometer\n  |> keep(columns: [\"_value\", \"spectrometer\"])\n\n// Join current levels with loss rates\njoin(\n  tables: {current: currentLevels, rate: heliumLossRates},\n  on: [\"spectrometer\"]\n)\n  |> map(fn: (r) => ({\n      _time: r._time,\n      _value: (r._value_current - minLevel) / r._value_rate,  // Days until minimum\n      spectrometer: r.spectrometer\n  }))\n  |> rename(columns: {_value: \"days_remaining\"})\n  |> yield(name: \"time_until_minimum\")",
          "refId": "A"
        }
      ],
      "title": "Days remaining to 70%",
      "type": "stat"
    },
